APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

DB_NAME=sciguide
DB_USER=postgres
DB_PASSWORD=test
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

WORKSPACE_LIFECYCLE_MODE=http
WORKSPACE_LIFECYCLE_TIMEOUT_SECONDS=10.0

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PREFIX=workspace_
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false

NEO4J_URL=http://neo4j:7474
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
NEO4J_WORKSPACE_ROOT_LABEL=WorkspaceGraphRoot
PIPELINE_NEO4J_URI=bolt://neo4j:7687

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=workspace-documents
MINIO_REGION=

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free

PIPELINE_EMBEDDING_MODEL_NAME=BAAI/bge-m3
PIPELINE_RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
PIPELINE_MODEL_CACHE_DIR=/app/hf_cache
PIPELINE_CHUNK_SIZE=900
PIPELINE_CHUNK_OVERLAP=120
PIPELINE_REQUEST_TIMEOUT_SECONDS=60.0
HUGGINGFACE_TOKEN=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
